{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "app/api/scan/route.ts": {
      "maxDuration": 60
    },
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/webhooks/cron/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/webhooks/cron",
      "schedule": "0 */6 * * *"
    }
  ]
}
