# TEMPLATE SAJA — salin ke .env.local lalu isi nilai nyata di .env.local
# JANGAN menaruh secret/publishable key asli di file ini (bisa ter-commit ke GitHub).

# Anthropic
ANTHROPIC_API_KEY=

# Nimble — Bearer API key (SDK) ATAU Basic Auth legacy
NIMBLE_API_KEY=
NIMBLE_USERNAME=
NIMBLE_PASSWORD=

# Supabase (Publishable + Secret dari Dashboard → API Keys)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (Hari 9 — alert kritis + welcome)
RESEND_API_KEY=
# Opsional — domain terverifikasi; dev: MediGuard AI <onboarding@resend.dev>
RESEND_FROM=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
CRON_SECRET=

# Demo mode — set true untuk skip Nimble/Claude saat demo live
# Scan Now akan memakai alert yang sudah di-cache (lib/scan/demo-fallback.ts)
# AI Chat tetap memakai Nimble live selama NIMBLE_API_KEY terisi
DEMO_FALLBACK=false

# Petunjuk login juri di /login (email + password ditampilkan & pre-fill form)
NEXT_PUBLIC_DEMO_JUDGE_HINT=false
NEXT_PUBLIC_DEMO_JUDGE_EMAIL=demo@mediguard.adindamochamad.com
NEXT_PUBLIC_DEMO_JUDGE_PASSWORD=MediGuardDemo2026!
