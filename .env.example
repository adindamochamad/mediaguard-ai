# TEMPLATE SAJA — salin ke .env.local lalu isi nilai nyata di .env.local
# JANGAN menaruh secret/publishable key asli di file ini (bisa ter-commit ke GitHub).

# Anthropic
ANTHROPIC_API_KEY=

# Nimble — Bearer API key (SDK) ATAU Basic Auth legacy
NIMBLE_API_KEY=
