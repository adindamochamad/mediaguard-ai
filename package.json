{
  "name": "mediaguard-ai",
  "version": "0.1.0",
  "private": true,
  "description": "MediGuard AI — keselamatan obat realtime (DeveloperWeek NYC 2026)",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "verify": "node scripts/verify-project.mjs && node scripts/verify-teks-medis.mjs",
    "test": "node scripts/run-tests.mjs",
    "agents": "node scripts/run-agents.mjs",
    "test:polish": "node --env-file=.env.local scripts/uji-polish-day1-2.mjs",
    "setup:git-hooks": "node scripts/setup-git-hooks.mjs",
    "video:dev": "npm run dev --prefix video",
    "video:render": "npm run render --prefix video"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@headlessui/react": "^2.2.10",
    "@react-email/components": "^1.0.12",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
